{
  "expo": {
    "name": "Tienda Saku",
    "slug": "tienda-saku",
    "version": "10.90.21",
    "orientation": "portrait",
    "icon": "./assets/images/logo_saku_cl.png",
    "scheme": "tiendasaku",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo_saku_cl.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.SAKUtienda.cl",
      "buildNumber": "56",
      "appleTeamId": "4H4BJH5HJX",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:saku-tienda.web.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.SAKUtienda.cl",
      "versionCode": 53,
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "saku-tienda.web.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/logo_saku_cl.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo_saku_cl.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/ic_stat_notification.png",
          "color": "#63348C",
          "sounds": [
            "./assets/audio/saku_compra.mp3"
          ]
        }
      ],
      "expo-video",
      "expo-image",
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a57684e9-cbfa-45dc-8991-74193b1b62a7"
      }
    }
  }
}
